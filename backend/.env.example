# ---------------------------------------------------------------------------
# AI Product Studio - backend config
# Copy this file to ".env" and fill in what you have. Everything is optional:
# with no keys set, ALL agents run locally on Ollama (free, no GPU needed).
# ---------------------------------------------------------------------------

# --- Local inference (Ollama) ---
OLLAMA_BASE_URL=http://localhost:11434

# Default local models per size tier. Change to whatever you've `ollama pull`ed.
LOCAL_MODEL_SMALL=llama3.2:3b
LOCAL_MODEL_MEDIUM=qwen3:8b
# Optional lighter frontend model if RAM is tight (falls back to MEDIUM if unset)
LOCAL_MODEL_FRONTEND=qwen3:4b

# --- Cloud APIs (optional) ---
# Leave blank to route the heavy agents (PM, Reviewer) to local models instead.

# Moonshot / Kimi K2 -- Project Manager agent
# Get a key at https://platform.moonshot.ai  (OpenAI-compatible API)
MOONSHOT_API_KEY=
MOONSHOT_BASE_URL=https://api.moonshot.ai/v1
MOONSHOT_MODEL=kimi-k2-0711-preview

# DeepSeek V4-Flash (thinking mode) -- Code Reviewer agent
# Get a key at https://platform.deepseek.com  (5M free tokens for new accounts)
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-reasoner

# --- OpenRouter (single key powers PM, Reviewer, AND Frontend agents) ---
# IMPORTANT: only use model slugs ending in ":free" (or otherwise $0-priced) to
# guarantee you are never charged. Free slugs change often — run
#   .venv\Scripts\python.exe list_free_models.py
# to print the models that are FREE on YOUR account right now, then paste the
# suggested slugs below. Non-free slugs bill per token even for a single user.
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# --- Production persistence / server-side daily limit (Render) ---
# Keep the service role key on the backend only. When both are set, /run
# requires a Supabase bearer token and persists each completed run server-side.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Comma-separated browser origins allowed to call the API.
FRONTEND_ORIGIN=http://localhost:3000,http://127.0.0.1:3000

# Each var is a COMMA-SEPARATED FALLBACK CHAIN. Free models get congested
# independently (HTTP 429), so each is tried in order, then a local Ollama model
# is used as the final safety net so a run always completes.

# Frontend / Backend Engineers -> free coding models (best code + UI mockups).
OPENROUTER_FRONTEND_MODEL=qwen/qwen3-coder:free,poolside/laguna-m.1:free,cohere/north-mini-code:free
OPENROUTER_BACKEND_MODEL=poolside/laguna-m.1:free,cohere/north-mini-code:free,qwen/qwen3-coder:free
# Product Manager & Code Reviewer -> free general/reasoning models.
OPENROUTER_PM_MODEL=nvidia/nemotron-3-ultra-550b-a55b:free,nvidia/nemotron-3-super-120b-a12b:free
OPENROUTER_REVIEWER_MODEL=nvidia/nemotron-3-ultra-550b-a55b:free,nvidia/nemotron-3-super-120b-a12b:free
