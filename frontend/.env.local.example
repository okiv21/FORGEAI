# Copy to .env.local (local dev) and set the same vars in Vercel (Production).

# FastAPI backend base URL. Local dev talks to localhost; in production set this
# to your Render URL, e.g. https://ai-product-studio-api.onrender.com
NEXT_PUBLIC_API_BASE=http://localhost:8000

# Supabase (browser) — the PUBLIC anon key only. Never put the service_role key here.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY
